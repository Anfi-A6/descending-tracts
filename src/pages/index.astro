---
import Layout from "@layouts/Layout.astro"
import generalAnterior from '@images/general_anterior.png'
import generalLateral from '@images/general_lateral.png'

const teamMembers = [
  "Avila Fernandez Sandra Paola",
  "Gomez Campero Rafael",
  "Gonzalez Rocha Uriel",
  "Grimaldo Hernandez Scarlett Gioconda",
  "Guell Segura Ana Sofia",
  "Guerrero Morales Daniela Montserrat",
  "Gutierrez Rodriguez Ofelia",
  "Hernandez Herrera Ana Valeria",
  "Hernandez Lara Aram",
]

// Replace these with your actual 3D model image paths
const modelImages = [
  { src: generalAnterior.src, alt: "Vista general anterior del modelo" },
  { src: generalLateral.src, alt: "Vista general lateral" },
]
---

<Layout pageTitle="Bienvenida">

  <!-- Hero Section -->
  <div class="hero min-h-[40vh] rounded-box bg-base-200 mb-8">
    <div class="hero-content text-center">
      <div class="max-w-2xl">
        <div class="badge badge-primary badge-outline mb-4">Mesa 6 Anfiteatro</div>
        <h1 class="text-4xl font-bold mb-4">Vías Descendentes del Tronco Encefálico</h1>
        <p class="text-base-content/70 text-lg mb-6">
          Explora las estructuras de las vías de salida del puente y mesencéfalo a través
          de nuestro modelo tridimensional interactivo. Haz clic sobre cualquier estructura
          en los cortes para identificarla.
        </p>
        <a href="#niveles" class="btn btn-primary">
          Explorar niveles
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Carousel -->
  <div class="mb-10">
    <h2 class="text-2xl font-bold mb-4">Nuestro Modelo</h2>
    <div class="carousel carousel-center w-full rounded-box space-x-4 bg-base-200 p-4">
      {modelImages.map((img, i) => (
        <div class="carousel-item">
          <div class="card bg-base-100 w-72 shadow-md">
            <figure class="h-48 bg-base-300">
              <img
                src={img.src}
                alt={img.alt}
                class="object-cover w-full h-full"
                onerror="this.parentElement.innerHTML='<div class=\'flex items-center justify-center w-full h-full text-base-content/30 text-sm\'>' + this.alt + '</div>'"
              />
            </figure>
            <div class="card-body p-3">
              <p class="text-sm text-base-content/70 text-center">{img.alt}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- How to use -->
  <div class="mb-10" id="niveles">
    <h2 class="text-2xl font-bold mb-4">¿Cómo usar este sitio?</h2>
    <div class="steps steps-vertical lg:steps-horizontal w-full">
      <div class="step step-primary">
        <div class="step-content text-left ml-2 lg:ml-0 lg:mt-2">
          <p class="font-semibold text-sm">Selecciona un nivel</p>
          <p class="text-xs text-base-content/60">Usa el menú de navegación superior</p>
        </div>
      </div>
      <div class="step step-primary">
        <div class="step-content text-left ml-2 lg:ml-0 lg:mt-2">
          <p class="font-semibold text-sm">Haz clic en la imagen</p>
          <p class="text-xs text-base-content/60">Toca cualquier estructura del corte</p>
        </div>
      </div>
      <div class="step step-primary">
        <div class="step-content text-left ml-2 lg:ml-0 lg:mt-2">
          <p class="font-semibold text-sm">Identifica la estructura</p>
          <p class="text-xs text-base-content/60">Aparecerá su nombre al instante</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Team -->
  <div class="mb-6">
    <h2 class="text-2xl font-bold mb-4">Integrantes del equipo</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
      {teamMembers.map((member) => (
        <div class="flex items-center gap-3 p-3 rounded-box bg-base-200 hover:bg-base-300 transition-colors">
          <div class="avatar placeholder">
            <div class="bg-primary text-primary-content rounded-full w-8 text-center">
              <span class="text-xs font-bold">{member.split(" ")[0][0]}{member.split(" ")[1]?.[0] ?? ""}</span>
            </div>
          </div>
          <span class="text-sm font-medium">{member.toUpperCase()}</span>
        </div>
      ))}
    </div>
  </div>

</Layout>